{
  "functions": {
    "api/chat.js": {
      "memory": 128,
      "maxDuration": 20
    },
    "api/transcribe.js": {
      "memory": 256,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/((?!api/.*).*)", "destination": "/index.html" }
  ]
}
