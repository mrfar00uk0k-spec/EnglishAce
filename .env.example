# ─────────────────────────────────────────────────────────────────────────────
# EnglishAce — Environment Variables
# Copy this file to .env.local (for local dev) and set the same variables in
# your hosting provider's dashboard (e.g. Vercel → Project → Settings →
# Environment Variables) for production.
# ─────────────────────────────────────────────────────────────────────────────

# REQUIRED — at least one Groq API key.
# Get a free key at https://console.groq.com/keys
# Used for: Whisper speech-to-text transcription (Speaking, HR Interview) and
# the LLM calls that evaluate every assessment (Speaking, Writing, HR Interview).
GROQ_API_KEY=your_groq_api_key_here

# OPTIONAL — additional keys for round-robin rotation / higher rate limits.
# The app automatically spreads requests across every key you provide below.
# Leave blank / remove any you don't have.
GROQ_API_KEY_1=
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=
GROQ_API_KEY_6=
GROQ_API_KEY_7=
GROQ_API_KEY_8=
GROQ_API_KEY_9=
GROQ_API_KEY_10=
